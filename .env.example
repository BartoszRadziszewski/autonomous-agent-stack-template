# Google AI Studio API Key - pobierz z https://aistudio.google.com/
GOOGLE_API_KEY=YOUR_API_KEY_HERE

# Klucz do weryfikacji integralności (dowolny długi ciąg znaków)
INTEGRITY_SECRET=random_string_for_security_checks

# Ścieżka do lokalnych danych (opcjonalnie)
DATA_PATH=./data

# Debugowanie
DEBUG=True